<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>우리 반 한글 놀이터</title>
    <style>
        @font-face {
            font-family: 'OngleipParkDahyeon';
            src: url('https://cdn.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Ownglyph_ParkDaHyun.woff2') format('woff2');
            font-weight: normal; font-display: swap;
        }
        :root { --primary: #ff8fb1; --secondary: #4db6ac; --bg: #fffbf5; --error: #ff5252; }
        * { font-family: 'OngleipParkDahyeon', cursive !important; box-sizing: border-box; }
        body { background-color: var(--bg); text-align: center; padding: 0; margin: 0; color: #444; overflow-x: hidden; }

        /* 설정 페이지 */
        #admin-page { padding: 20px; display: flex; flex-direction: column; align-items: center; min-height: 100vh; background: white; }
        .setup-box { width: 100%; max-width: 500px; padding: 30px; border-radius: 30px; border: 3px solid var(--primary); background: #fff; }
        .upload-btn { display: block; width: 100%; padding: 15px; margin: 10px 0; background: #fdfdfd; border: 2px dashed #ffcadb; border-radius: 15px; cursor: pointer; color: #ff8fb1; font-weight: bold; }
        .upload-btn.done { border-color: var(--secondary); background: #f1f8e9; color: #2e7d32; }
        
        /* 🌟 미리보기 테이블 스타일 */
        #preview-area { margin-top: 20px; width: 100%; max-height: 300px; overflow-y: auto; border: 1px solid #eee; border-radius: 10px; display: none; }
        .preview-table { width: 100%; border-collapse: collapse; font-size: 14px; }
        .preview-table th, .preview-table td { border: 1px solid #eee; padding: 8px; text-align: center; }
        .preview-table img { width: 40px; height: 40px; object-fit: cover; border-radius: 5px; }

        .entry-btn { width: 100%; padding: 20px; background: var(--primary); color: white; border: none; border-radius: 50px; font-size: 24px; font-weight: bold; cursor: pointer; margin-top: 20px; display: none; }

        /* 게임 화면 */
        #game-page { display: none; padding: 20px; }
        .bgm-toggle { position: fixed; top: 10px; right: 10px; z-index: 100; background: white; border: 2px solid var(--primary); border-radius: 50px; padding: 8px 12px; cursor: pointer; }
        .draw-btn { font-size: 24px; padding: 15px 40px; background: var(--secondary); color: white; border: none; border-radius: 50px; cursor: pointer; margin-bottom: 20px; }
        .word-container { display: flex; justify-content: center; gap: 10px; margin: 20px auto; flex-wrap: wrap; }
        .syllable { background: white; border: 3px solid #ffdeeb; border-radius: 20px; padding: 15px; min-width: 100px; display: flex; flex-direction: column; align-items: center; }
        .syllable.all-clear { border-color: #81c784; background: #f1f8e9; }
        .cho-box, .jong-box { width: 45px; height: 45px; border: 2px dashed #ffcadb; display: flex; align-items: center; justify-content: center; font-size: 30px; border-radius: 10px; color: #ffdee8; }
        .cho-box.open, .jong-box.open { border: 3px solid #81c784; color: #2e7d32; background: white; }
        .jung-text { font-size: 50px; color: #ff5252; line-height: 1; }

        .keyboard-container { max-width: 600px; margin: 20px auto; display: flex; flex-direction: column; gap: 8px; }
        .keyboard-row { display: flex; justify-content: center; gap: 5px; }
        .key { width: 55px; height: 55px; background: white; border: 2px solid #ffdeeb; border-radius: 12px; font-size: 24px; cursor: pointer; box-shadow: 0 3px 0 #ffdeeb; }
        .key.hit { background: #81c784 !important; color: white !important; border: none; }
        .key.miss { background: var(--error) !important; color: white !important; border: none; }
        .key.shake { animation: shake 0.4s; }
        @keyframes shake { 0%, 100% {transform:translateX(0)} 20%, 60% {transform:translateX(-5px)} 40%, 80% {transform:translateX(5px)} }

        /* 모달 */
        #photo-modal { display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 20px; border-radius: 30px; border: 6px solid var(--primary); z-index: 1000; width: 320px; text-align: center; }
        #photo-modal img { width: 100%; height: 300px; object-fit: cover; border-radius: 20px; margin-bottom: 10px; }
        #modal-overlay { display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index: 999; }
        input[type="file"] { display: none; }
    </style>
</head>
<body>

    <div id="admin-page">
        <div class="setup-box">
            <h2>⚙️ 선생님 설정</h2>
            <p style="font-size: 14px; color: #888;">명단 순서와 사진 선택 순서가 매칭됩니다.</p>
            <label for="nameInput" id="name-btn" class="upload-btn">1. 명단(.txt) 불러오기</label>
            <input type="file" id="nameInput" accept=".txt">
            
            <label for="photoInput" id="photo-btn" class="upload-btn">2. 사진들 뭉땅 선택</label>
            <input type="file" id="photoInput" accept="image/*" multiple>

            <div id="preview-area">
                <table class="preview-table" id="preview-table">
                    <thead><tr><th>순번</th><th>이름</th><th>사진 미리보기</th></tr></thead>
                    <tbody id="preview-tbody"></tbody>
                </table>
            </div>

            <button class="entry-btn" id="entryBtn" onclick="startGame()">놀이터 입장! 🎲</button>
        </div>
    </div>

    <div id="game-page">
        <button class="bgm-toggle" id="bgmBtn" onclick="toggleBgm()">소리 켬 🔊</button>
        <h1 style="font-size: 30px;">🍓 우리 반 한글 놀이터</h1>
        <button class="draw-btn" onclick="nextGame()">주인공 나와라 얍! 🎲</button>
        <div id="msg" style="font-size: 20px; color: var(--secondary); height: 30px;"></div>
        <div class="word-container" id="display"></div>
        <div class="keyboard-container" id="kbd"></div>

        <div id="modal-overlay" onclick="closeModal()"></div>
        <div id="photo-modal">
            <img id="winner-img" src="">
            <div id="winner-name" style="font-size:30px; color:var(--primary); font-weight:bold;"></div>
            <button onclick="nextGame()" style="margin-top:10px; padding:10px 20px; border-radius:15px; border:none; background:var(--secondary); color:white;">다음 친구 ➔</button>
        </div>
    </div>

    <script>
        const CHO = ["ㄱ","ㄲ","ㄴ","ㄷ","ㄸ","ㄹ","ㅁ","ㅂ","ㅃ","ㅅ","ㅆ","ㅇ","ㅈ","ㅉ","ㅊ","ㅋ","ㅌ","ㅍ","ㅎ"];
        const JUNG = ["ㅏ","ㅐ","ㅑ","ㅒ","ㅓ","ㅔ","ㅕ","ㅖ","ㅗ","ㅘ","ㅙ","ㅚ","ㅛ","ㅜ","ㅝ","ㅞ","ㅟ","ㅠ","ㅡ","ㅢ","ㅣ"];
        const JONG = ["","ㄱ","ㄲ","ㄳ","ㄴ","ㄵ","ㄶ","ㄷ","ㄹ","ㄺ","ㄻ","ㄼ","ㄽ","ㄾ","ㄿ","ㅀ","ㅁ","ㅂ","ㅄ","ㅅ","ㅆ","ㅇ","ㅈ","ㅊ","ㅋ","ㅌ","ㅍ","ㅎ"];
        const KEYBOARD_LAYOUT = [["ㄱ","ㄴ","ㄷ","ㄹ","ㅁ","ㅂ","ㅅ"],["ㅇ","ㅈ","ㅊ","ㅋ","ㅌ","ㅍ","ㅎ"],["ㄲ","ㄸ","ㅃ","ㅆ","ㅉ"]];

        let names = [], unplayed = [], currentWord = "", state = [], photoMap = {};
        let audioCtx = null, isBgmOn = true;
        const bgm = new Audio('Mr. Turtle - The Green Orbs.mp3');
        bgm.loop = true; bgm.volume = 0.2;

        function playSuccessSound() {
            if(!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            if(audioCtx.state === 'suspended') audioCtx.resume();
            const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
            osc.connect(gain); gain.connect(audioCtx.destination);
            osc.type = 'sine'; osc.frequency.setValueAtTime(523.25, audioCtx.currentTime);
            osc.frequency.exponentialRampToValueAtTime(1046.50, audioCtx.currentTime + 0.1);
            gain.gain.setValueAtTime(0.2, audioCtx.currentTime); gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.4);
            osc.start(); osc.stop(audioCtx.currentTime + 0.4);
        }

        function toggleBgm() {
            if(isBgmOn) { bgm.pause(); document.getElementById('bgmBtn').innerText = "소리 끔 🔇"; } 
            else { bgm.play(); document.getElementById('bgmBtn').innerText = "소리 켬 🔊"; }
            isBgmOn = !isBgmOn;
        }

        // 명단 불러오기
        document.getElementById('nameInput').addEventListener('change', function(e) {
            const reader = new FileReader();
            reader.onload = (re) => {
                names = re.target.result.match(/[가-힣]+/g) || [];
                unplayed = [...names];
                document.getElementById('name-btn').innerText = `✅ 명단 완료 (${names.length}명)`;
                document.getElementById('name-btn').classList.add('done');
                updatePreview();
            };
            reader.readAsText(e.target.files[0], "UTF-8");
        });

        // 사진 불러오기 및 미리보기 생성
        document.getElementById('photoInput').addEventListener('change', async function(e) {
            const files = Array.from(e.target.files);
            // 파일명 정렬
            files.sort((a, b) => a.name.localeCompare(b.name, undefined, {numeric: true}));
            
            photoMap = {};
            const promises = files.map((file, index) => {
                return new Promise((resolve) => {
                    const reader = new FileReader();
                    reader.onload = (re) => {
                        const targetName = names[index];
                        if(targetName) photoMap[targetName] = re.target.result;
                        resolve();
                    };
                    reader.readAsDataURL(file);
                });
            });
            await Promise.all(promises);
            document.getElementById('photo-btn').innerText = `✅ 사진 완료 (${Object.keys(photoMap).length}장)`;
            document.getElementById('photo-btn').classList.add('done');
            updatePreview();
        });

        // 🌟 미리보기 테이블 업데이트
        function updatePreview() {
            const tbody = document.getElementById('preview-tbody');
            tbody.innerHTML = "";
            if (names.length > 0) {
                document.getElementById('preview-area').style.display = "block";
                names.forEach((name, i) => {
                    const tr = document.createElement('tr');
                    const photo = photoMap[name];
                    tr.innerHTML = `<td>${i+1}</td><td>${name}</td><td>${photo ? `<img src="${photo}">` : "<span style='color:red'>사진없음</span>"}</td>`;
                    tbody.appendChild(tr);
                });
            }
            if (names.length > 0 && Object.keys(photoMap).length > 0) {
                document.getElementById('entryBtn').style.display = 'block';
            }
        }

        function startGame() { bgm.play().catch(()=>{}); document.getElementById('admin-page').style.display = 'none'; document.getElementById('game-page').style.display = 'block'; }

        function nextGame() {
            closeModal();
            if (unplayed.length === 0) { alert("모든 친구들을 만났어요! 처음부터 다시 시작합니다."); unplayed = [...names]; }
            currentWord = unplayed.splice(Math.floor(Math.random() * unplayed.length), 1)[0];
            state = Array.from(currentWord).map(char => {
                const code = char.charCodeAt(0) - 44032;
                const jongIdx = code % 28, jungIdx = ((code - jongIdx) / 28) % 21, choIdx = Math.floor(((code - jongIdx) / 28) / 21);
                return { cho: CHO[choIdx], jung: JUNG[jungIdx], jong: JONG[jongIdx], choOpen: false, jongOpen: JONG[jongIdx] === "" };
            });
            document.getElementById('msg').innerText = "누구일까? 자음을 눌러봐!";
            renderWord(); renderKeyboard();
        }

        function renderWord() {
            const container = document.getElementById('display'); container.innerHTML = "";
            state.forEach(s => {
                const div = document.createElement('div'); div.className = "syllable";
                const isSide = ["ㅏ","ㅐ","ㅑ","ㅒ","ㅓ","ㅔ","ㅕ","ㅖ","ㅣ"].includes(s.jung);
                div.innerHTML = `<div style="display:flex; flex-direction:${isSide?'row':'column'}; align-items:center; gap:5px;">
                    <div class="cho-box ${s.choOpen?'open':''}">${s.choOpen?s.cho:'?'}</div>
                    <div class="jung-text">${s.jung}</div></div>
                    ${s.jong !== "" ? `<div class="jong-box ${s.jongOpen?'open':''}" style="margin-top:5px;">${s.jongOpen?s.jong:'?'}</div>` : ""}`;
                if (s.choOpen && s.jongOpen) div.classList.add('all-clear');
                container.appendChild(div);
            });
        }

        function renderKeyboard() {
            const kbd = document.getElementById('kbd'); kbd.innerHTML = "";
            KEYBOARD_LAYOUT.forEach(row => {
                const rowDiv = document.createElement('div'); rowDiv.className = "keyboard-row";
                row.forEach(c => {
                    const b = document.createElement('button'); b.className = 'key'; b.innerText = c;
                    b.onclick = () => guess(c, b); rowDiv.appendChild(b);
                });
                kbd.appendChild(rowDiv);
            });
        }

        function guess(c, btn) {
            let found = false;
            state.forEach(s => {
                if (s.cho === c && !s.choOpen) { s.choOpen = true; found = true; }
                if (s.jong === c && !s.jongOpen) { s.jongOpen = true; found = true; }
            });
            if (found) { btn.classList.add('hit'); renderWord(); if (state.every(s => s.choOpen && s.jongOpen)) { playSuccessSound(); setTimeout(showModal, 300); } } 
            else { btn.classList.add('miss'); btn.classList.add('shake'); setTimeout(() => btn.classList.remove('shake'), 400); }
        }

        function showModal() {
            document.getElementById('winner-name').innerText = currentWord;
            const photoData = photoMap[currentWord];
            const img = document.getElementById('winner-img');
            if (photoData) { img.src = photoData; img.style.display = "block"; } 
            else { img.style.display = "none"; }
            document.getElementById('modal-overlay').style.display = "block";
            document.getElementById('photo-modal').style.display = "block";
        }
        function closeModal() { document.getElementById('modal-overlay').style.display = "none"; document.getElementById('photo-modal').style.display = "none"; }
    </script>
</body>
</html>
